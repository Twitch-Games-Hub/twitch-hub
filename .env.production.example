# =============================================================================
# Twitch Hub — Production Environment Variables
# Copy to .env.production and fill in the values.
# Run ./scripts/deploy.sh secrets to auto-generate passwords/secrets.
# =============================================================================

# ---- Domain ----
APP_DOMAIN=example.com
API_DOMAIN=api.example.com

# ---- Database ----
POSTGRES_USER=twitch_hub
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=twitch_hub

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME

# ---- Auth ----
JWT_SECRET=CHANGE_ME
INTERNAL_API_SECRET=CHANGE_ME

# ---- GitHub Container Registry (required for CI/CD image pulls) ----
GITHUB_USERNAME=your_github_username
GHCR_TOKEN=ghp_your_personal_access_token
GHCR_SERVER_IMAGE=ghcr.io/your_github_username/twitch-hub-server:latest
GHCR_WEB_IMAGE=ghcr.io/your_github_username/twitch-hub-web:latest

# ---- Webhook Deploy (required for automated CD via webhookd) ----
WEBHOOK_SECRET=CHANGE_ME

# ---- Twitch OAuth ----
TWITCH_CLIENT_ID=your_client_id
TWITCH_CLIENT_SECRET=your_client_secret

# ---- Stripe (optional — billing features disabled if missing) ----
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_MONTHLY_PRICE_ID=price_...
# STRIPE_ANNUAL_PRICE_ID=price_...
# STRIPE_CREDIT_PACK_PRICE_ID=price_...

# ---- Sentry (optional — error tracking disabled if missing) ----
# SENTRY_DSN=https://...@sentry.io/...
# PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
