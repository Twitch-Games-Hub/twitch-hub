# Production environment — generated by pyinfra
# Do not edit manually on the server; re-run `python run.py deploy` instead.

# GitHub Container Registry images
GHCR_SERVER_IMAGE=ghcr.io/{{ github_username }}/twitch-hub-server:latest
GHCR_WEB_IMAGE=ghcr.io/{{ github_username }}/twitch-hub-web:latest

# Domains
APP_DOMAIN={{ app_domain }}
API_DOMAIN={{ api_domain }}

# Database
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB={{ postgres_db }}

# Redis
REDIS_PASSWORD={{ redis_password }}

# Auth
JWT_SECRET={{ jwt_secret }}
INTERNAL_API_SECRET={{ internal_api_secret }}

# Twitch
TWITCH_CLIENT_ID={{ twitch_client_id }}
TWITCH_CLIENT_SECRET={{ twitch_client_secret }}

# Stripe (optional)
STRIPE_SECRET_KEY={{ stripe_secret_key }}
STRIPE_WEBHOOK_SECRET={{ stripe_webhook_secret }}
STRIPE_MONTHLY_PRICE_ID={{ stripe_monthly_price_id }}
STRIPE_ANNUAL_PRICE_ID={{ stripe_annual_price_id }}
STRIPE_CREDIT_PACK_PRICE_ID={{ stripe_credit_pack_price_id }}

# Sentry (optional)
SENTRY_DSN={{ sentry_dsn }}
PUBLIC_SENTRY_DSN={{ public_sentry_dsn }}
SENTRY_AUTH_TOKEN={{ sentry_auth_token }}
SENTRY_ORG={{ sentry_org }}
SENTRY_PROJECT={{ sentry_project }}
