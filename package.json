{
  "name": "twitch-hub",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter './apps/*' run dev",
    "build": "pnpm --filter @twitch-hub/shared-types run build && pnpm --filter './apps/*' run build",
    "lint": "pnpm --filter '*' run lint",
    "format": "pnpm --filter '*' run format",
    "format:check": "prettier --check .",
    "typecheck": "pnpm --filter '*' run typecheck",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck",
    "test": "pnpm --filter '*' run test",
    "clean": "pnpm --filter '*' run clean",
    "docs:dev": "pnpm --filter @twitch-hub/docs run dev",
    "docs:build": "pnpm --filter @twitch-hub/docs run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "esbuild",
      "@sentry/cli"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
