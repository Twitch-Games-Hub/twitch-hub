generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String     @id @default(cuid())
  twitchId        String     @unique
  twitchLogin     String
  displayName     String
  profileImageUrl String?
  accessToken     String
  refreshToken    String
  tokenExpiresAt  DateTime
  role            UserRole   @default(VIEWER)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  ownedGames      Game[]
  responses       Response[]
}

enum UserRole {
  STREAMER
  VIEWER
}

model Game {
  id        String     @id @default(cuid())
  ownerId   String
  owner     User       @relation(fields: [ownerId], references: [id])
  type      GameType
  title     String
  config    Json
  status    GameStatus @default(DRAFT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  sessions  GameSession[]
}

enum GameType {
  BRACKET
  BALANCE
  PERSONALITY
  HOT_TAKE
  TIER_LIST
  BLIND_TEST
}

enum GameStatus {
  DRAFT
  READY
  ARCHIVED
}

model GameSession {
  id           String        @id @default(cuid())
  gameId       String
  game         Game          @relation(fields: [gameId], references: [id])
  hostId       String
  channelId    String
  status       SessionStatus @default(WAITING)
  currentRound Int           @default(0)
  state        Json          @default("{}")
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime      @default(now())
  responses    Response[]
}

enum SessionStatus {
  WAITING
  ACTIVE
  PAUSED
  COMPLETED
}

model Response {
  id          String         @id @default(cuid())
  sessionId   String
  session     GameSession    @relation(fields: [sessionId], references: [id])
  userId      String?
  user        User?          @relation(fields: [userId], references: [id])
  twitchLogin String?
  round       Int
  questionId  String
  answer      Json
  source      ResponseSource
  respondedAt DateTime       @default(now())

  @@unique([sessionId, userId, round, questionId])
  @@unique([sessionId, twitchLogin, round, questionId])
}

enum ResponseSource {
  WEB
  CHAT
}
