generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String     @id @default(cuid())
  twitchId        String     @unique
  twitchLogin     String
  displayName     String
  profileImageUrl String?
  accessToken     String
  refreshToken    String
  tokenExpiresAt  DateTime
  role            UserRole   @default(VIEWER)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  ownedGames      Game[]
  responses       Response[]
  ratings         GameRating[]
  bookmarks       GameBookmark[]
  subscription    Subscription?
  moderatorLinks  ModeratorLink[] @relation("StreamerMods")
  notifications   Notification[]  @relation("UserNotifications")
  playerProfile   PlayerProfile?
}

enum UserRole {
  STREAMER
  VIEWER
}

model Game {
  id            String     @id @default(cuid())
  ownerId       String
  owner         User       @relation(fields: [ownerId], references: [id])
  type          GameType
  title         String
  description   String?
  coverImageUrl String?
  config        Json
  status        GameStatus @default(DRAFT)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  sessions      GameSession[]
  ratings       GameRating[]
  bookmarks     GameBookmark[]
}

enum GameType {
  BALANCE
  HOT_TAKE
  BLIND_TEST
  RANKING
}

enum GameStatus {
  DRAFT
  READY
  ARCHIVED
}

model GameSession {
  id           String        @id @default(uuid())
  gameId       String
  game         Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  hostId       String
  channelId    String
  status       SessionStatus @default(LOBBY)
  currentRound Int           @default(0)
  state        Json          @default("{}")
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime      @default(now())
  responses    Response[]

  @@index([hostId])
}

enum SessionStatus {
  LOBBY
  LIVE
  ENDED
}

model Response {
  id          String         @id @default(cuid())
  sessionId   String
  session     GameSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?          @relation(fields: [userId], references: [id])
  twitchLogin String?
  round       Int
  questionId  String
  answer      Json
  source      ResponseSource
  respondedAt DateTime       @default(now())

  @@unique([sessionId, userId, round, questionId])
  @@unique([sessionId, twitchLogin, round, questionId])
}

enum ResponseSource {
  WEB
  CHAT
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model Subscription {
  id                    String              @id @default(cuid())
  userId                String              @unique
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeCustomerId      String?             @unique
  stripeSubscriptionId  String?             @unique
  stripePriceId         String?
  status                SubscriptionStatus?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean             @default(false)

  sessionCredits        Int                 @default(0)

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([stripeCustomerId])
}

model GameRating {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int      // +1 upvote, -1 downvote
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gameId, userId])
  @@index([gameId])
}

model GameBookmark {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([gameId, userId])
  @@index([userId])
}

model ModeratorLink {
  id             String   @id @default(cuid())
  streamerId     String
  streamer       User     @relation("StreamerMods", fields: [streamerId], references: [id], onDelete: Cascade)
  modTwitchId    String
  modLogin       String
  modDisplayName String
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([streamerId, modTwitchId])
  @@index([modTwitchId])
}

model Notification {
  id          String             @id @default(cuid())
  recipientId String
  recipient   User               @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  body        String
  data        Json               @default("{}")
  status      NotificationStatus @default(UNREAD)
  createdAt   DateTime           @default(now())

  @@index([recipientId, status])
  @@index([recipientId, createdAt])
}

enum NotificationType {
  SESSION_INVITE
}

enum NotificationStatus {
  UNREAD
  READ
  DISMISSED
}

// --- Player Progression ---

model PlayerProfile {
  id              String   @id @default(cuid())
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  twitchLogin     String?  @unique

  totalXp         Int      @default(0)
  level           Int      @default(1)
  totalSessions   Int      @default(0)
  totalResponses  Int      @default(0)
  correctAnswers  Int      @default(0)
  bestStreak      Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  xpTransactions  XpTransaction[]
  channelStats    ChannelPlayerStats[]
  achievements    PlayerAchievement[]

  @@index([totalXp])
}

model XpTransaction {
  id              String        @id @default(cuid())
  playerProfileId String
  playerProfile   PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  sessionId       String
  channelId       String
  amount          Int
  reason          XpReason
  createdAt       DateTime      @default(now())

  @@index([playerProfileId, createdAt])
  @@index([sessionId])
}

enum XpReason {
  PARTICIPATION
  ROUND_RESPONSE
  CORRECT_ANSWER
  SPEED_BONUS
  STREAK_BONUS
  MAJORITY_VOTER
  SESSION_COMPLETION
  FIRST_RESPONDER
}

model ChannelPlayerStats {
  id              String      @id @default(cuid())
  playerProfileId String
  playerProfile   PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  channelId       String

  channelXp       Int         @default(0)
  loyaltyTier     LoyaltyTier @default(NEWCOMER)
  sessionsPlayed  Int         @default(0)
  currentStreak   Int         @default(0)
  bestStreak      Int         @default(0)
  lastPlayedAt    DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([playerProfileId, channelId])
  @@index([channelId, channelXp])
}

enum LoyaltyTier {
  NEWCOMER
  REGULAR
  DEDICATED
  SUPERFAN
  LEGENDARY
}

model AchievementDefinition {
  id          String              @id
  name        String
  description String
  category    AchievementCategory
  iconUrl     String?
  xpReward    Int                 @default(0)
  hidden      Boolean             @default(false)
  sortOrder   Int                 @default(0)
  players     PlayerAchievement[]
}

enum AchievementCategory {
  PARTICIPATION
  SKILL
  SOCIAL
  RARE
}

model PlayerAchievement {
  id                String                @id @default(cuid())
  playerProfileId   String
  playerProfile     PlayerProfile         @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  achievementId     String
  achievement       AchievementDefinition @relation(fields: [achievementId], references: [id])
  sessionId         String?
  earnedAt          DateTime              @default(now())

  @@unique([playerProfileId, achievementId])
  @@index([playerProfileId])
}
