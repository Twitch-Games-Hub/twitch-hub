{
  "name": "@twitch-hub/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch --preload ./src/instrument.ts src/index.ts | pino-pretty",
    "build": "bun build src/index.ts src/instrument.ts --target=bun --outdir=dist --sourcemap=external",
    "start": "node --import ./dist/instrument.js dist/index.js",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@sentry/node": "^10.40.0",
    "@twitch-hub/shared-types": "workspace:*",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
